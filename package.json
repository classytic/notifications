{
  "name": "@classytic/notifications",
  "version": "1.2.0",
  "description": "Multi-channel notification system with pluggable providers, templates, and retry - zero required dependencies",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./channels": {
      "types": "./dist/channels/index.d.mts",
      "default": "./dist/channels/index.mjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.mts",
      "default": "./dist/utils/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "notifications",
    "multi-channel",
    "email",
    "sms",
    "push",
    "webhook",
    "nodemailer",
    "smtp",
    "ses",
    "gmail",
    "event-driven",
    "templates",
    "retry",
    "pluggable",
    "framework-agnostic",
    "express",
    "fastify",
    "nestjs",
    "typescript",
    "zero-dependencies"
  ],
  "author": "Classytic <classytic.dev@gmail.com> (https://github.com/classytic)",
  "contributors": [
    "Sadman Chowdhury (https://github.com/siam923)"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/classytic/notifications.git"
  },
  "bugs": {
    "url": "https://github.com/classytic/notifications/issues"
  },
  "homepage": "https://github.com/classytic/notifications#readme",
  "peerDependencies": {
    "nodemailer": "^6.0.0 || ^7.0.0 || ^8.0.0"
  },
  "peerDependenciesMeta": {
    "nodemailer": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck",
    "publish:dry": "npm publish --dry-run --access public",
    "publish:npm": "npm publish --access public",
    "release": "npm run build && npm run typecheck && npm publish --access public",
    "release:patch": "npm version patch && npm run release",
    "release:minor": "npm version minor && npm run release",
    "release:major": "npm version major && npm run release"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.17",
    "@vitest/coverage-v8": "3.2.4",
    "nodemailer": "^6.10.1",
    "tsdown": "0.20.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}